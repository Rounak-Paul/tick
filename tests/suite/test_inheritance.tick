class Shape {
    var x : i32;
    var y : i32;

    func Shape(px : i32, py : i32) : void {
        this.x = px;
        this.y = py;
    }

    func get_x() : i32 {
        return this.x;
    }

    func get_y() : i32 {
        return this.y;
    }

    func area() : i32 {
        return 0;
    }
}

class Circle : Shape {
    var radius : i32;

    func Circle(px : i32, py : i32, r : i32) : void {
        this.x = px;
        this.y = py;
        this.radius = r;
    }

    func area() : i32 {
        return 3 * this.radius * this.radius;
    }

    func get_radius() : i32 {
        return this.radius;
    }
}

class Rect : Shape {
    var w : i32;
    var h : i32;

    func Rect(px : i32, py : i32, width : i32, height : i32) : void {
        this.x = px;
        this.y = py;
        this.w = width;
        this.h = height;
    }

    func area() : i32 {
        return this.w * this.h;
    }
}

func main() : i32 {
    var c : Circle = Circle(10, 20, 5);
    if (c.get_x() != 10) {
        println(c.get_x());
        return 1;
    }
    if (c.get_y() != 20) {
        println(c.get_y());
        return 1;
    }
    if (c.get_radius() != 5) {
        println(c.get_radius());
        return 1;
    }
    if (c.area() != 75) {
        println(c.area());
        return 1;
    }

    var r : Rect = Rect(0, 0, 4, 6);
    if (r.area() != 24) {
        println(r.area());
        return 1;
    }
    if (r.get_x() != 0) {
        return 1;
    }

    var s : Shape = Shape(1, 2);
    if (s.area() != 0) {
        return 1;
    }
    if (s.get_x() != 1) {
        return 1;
    }

    println("PASS: inheritance");
    return 0;
}
