func fib(n : i32) : i32 {
    if (n <= 1) {
        return n;
    } else {
        return fib(n - 1) + fib(n - 2);
    }
}

func fib_iterative(n : i32) : i32 {
    if (n <= 1) {
        return n;
    }
    
    var a : i32 = 0;
    var b : i32 = 1;
    var i : i32 = 2;
    
    while (i <= n) {
        var temp : i32 = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    
    return b;
}

func main() : i32 {
    var pass : i32 = 0;
    var fail : i32 = 0;
    
    println("=== Fibonacci Test ===");
    
    if (fib(0) == 0) {
        println("PASS: fib(0)");
        pass = pass + 1;
    } else {
        println("FAIL: fib(0)");
        fail = fail + 1;
    }
    
    if (fib(1) == 1) {
        println("PASS: fib(1)");
        pass = pass + 1;
    } else {
        println("FAIL: fib(1)");
        fail = fail + 1;
    }
    
    if (fib(5) == 5) {
        println("PASS: fib(5)");
        pass = pass + 1;
    } else {
        println("FAIL: fib(5)");
        fail = fail + 1;
    }
    
    if (fib(10) == 55) {
        println("PASS: fib(10)");
        pass = pass + 1;
    } else {
        println("FAIL: fib(10)");
        fail = fail + 1;
    }
    
    if (fib_iterative(10) == 55) {
        println("PASS: iterative fib(10)");
        pass = pass + 1;
    } else {
        println("FAIL: iterative fib(10)");
        fail = fail + 1;
    }
    
    if (fib_iterative(15) == 610) {
        println("PASS: iterative fib(15)");
        pass = pass + 1;
    } else {
        println("FAIL: iterative fib(15)");
        fail = fail + 1;
    }
    
    println("Passed: ");
    println(pass);
    println("Failed: ");
    println(fail);
    
    return fail;
}
