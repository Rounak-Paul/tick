func fib(n : i32) : i32 {
    if (n <= 1) {
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}

func factorial(n : i32) : i32 {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

func power(base : i32, exp : i32) : i32 {
    if (exp == 0) {
        return 1;
    }
    return base * power(base, exp - 1);
}

func gcd(a : i32, b : i32) : i32 {
    if (b == 0) {
        return a;
    }
    return gcd(b, a % b);
}

func main() : i32 {
    var pass : i32 = 0;
    var fail : i32 = 0;

    println("=== Recursion Test ===");

    if (fib(8) == 21) {
        println("PASS: fibonacci(8)");
        pass = pass + 1;
    } else {
        println("FAIL: fibonacci(8)");
        fail = fail + 1;
    }

    if (factorial(5) == 120) {
        println("PASS: factorial(5)");
        pass = pass + 1;
    } else {
        println("FAIL: factorial(5)");
        fail = fail + 1;
    }

    if (factorial(0) == 1) {
        println("PASS: factorial(0)");
        pass = pass + 1;
    } else {
        println("FAIL: factorial(0)");
        fail = fail + 1;
    }

    if (power(2, 10) == 1024) {
        println("PASS: power(2,10)");
        pass = pass + 1;
    } else {
        println("FAIL: power(2,10)");
        fail = fail + 1;
    }

    if (gcd(48, 18) == 6) {
        println("PASS: gcd(48,18)");
        pass = pass + 1;
    } else {
        println("FAIL: gcd(48,18)");
        fail = fail + 1;
    }

    if (gcd(100, 75) == 25) {
        println("PASS: gcd(100,75)");
        pass = pass + 1;
    } else {
        println("FAIL: gcd(100,75)");
        fail = fail + 1;
    }

    println("Passed: ");
    println(pass);
    println("Failed: ");
    println(fail);

    return fail;
}
