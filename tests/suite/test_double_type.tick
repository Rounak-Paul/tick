func test_double_arithmetic() : f64 {
    var a : f64 = 3.14;
    var b : f64 = 2.86;
    return a + b;
}

func test_double_multiply() : f64 {
    var x : f64 = 2.5;
    var y : f64 = 4.0;
    return x * y;
}

func test_float_to_int_compare() : i32 {
    var f : f64 = 10.0;
    if (f > 5.0) {
        return 1;
    }
    return 0;
}

func main() : i32 {
    var pass : i32 = 0;
    var fail : i32 = 0;

    println("=== Double Type Test ===");

    var sum : f64 = test_double_arithmetic();
    if (sum > 5.99 && sum < 6.01) {
        println("PASS: f64 addition");
        pass = pass + 1;
    } else {
        println("FAIL: f64 addition");
        fail = fail + 1;
    }

    var product : f64 = test_double_multiply();
    if (product > 9.99 && product < 10.01) {
        println("PASS: f64 multiplication");
        pass = pass + 1;
    } else {
        println("FAIL: f64 multiplication");
        fail = fail + 1;
    }

    if (test_float_to_int_compare() == 1) {
        println("PASS: f64 comparison");
        pass = pass + 1;
    } else {
        println("FAIL: f64 comparison");
        fail = fail + 1;
    }

    var d : f64 = 100.5;
    d = d - 0.5;
    if (d > 99.99 && d < 100.01) {
        println("PASS: f64 subtraction");
        pass = pass + 1;
    } else {
        println("FAIL: f64 subtraction");
        fail = fail + 1;
    }

    println("Passed: ");
    println(pass);
    println("Failed: ");
    println(fail);

    return fail;
}
