func stress_reassign() : i32 {
    var s : str = "seed";
    var i : i32 = 0;
    while (i < 3000) {
        s = s + "x";
        if (s.length() > 64) {
            s = "seed";
        }
        i = i + 1;
    }
    return s.length();
}

func stress_temporaries() : i32 {
    var i : i32 = 0;
    while (i < 4000) {
        to_str(i);
        "left" + "right";
        i = i + 1;
    }
    return i;
}

func free_then_reassign() : i32 {
    var s : str = to_str(99);
    free(s);
    s = to_str(100);
    if (str_compare(s, "100") == 0) {
        return 1;
    }
    return 0;
}

func main() : i32 {
    var fail : i32 = 0;

    var a : str = to_str(123);
    if (str_compare(a, "123") != 0) {
        println("FAIL: to_str i32");
        fail = fail + 1;
    } else {
        println("PASS: to_str i32");
    }

    var b : str = to_str(3.25);
    if (str_compare(b, "3.250000") != 0) {
        println("FAIL: to_str f64");
        fail = fail + 1;
    } else {
        println("PASS: to_str f64");
    }

    var c : str = to_str(true);
    if (str_compare(c, "true") != 0) {
        println("FAIL: to_str b8");
        fail = fail + 1;
    } else {
        println("PASS: to_str b8");
    }

    var len : i32 = stress_reassign();
    if (len <= 0) {
        println("FAIL: stress_reassign");
        fail = fail + 1;
    } else {
        println("PASS: stress_reassign");
    }

    var t : i32 = stress_temporaries();
    if (t != 4000) {
        println("FAIL: stress_temporaries");
        fail = fail + 1;
    } else {
        println("PASS: stress_temporaries");
    }

    var ok : i32 = free_then_reassign();
    if (ok != 1) {
        println("FAIL: free_then_reassign");
        fail = fail + 1;
    } else {
        println("PASS: free_then_reassign");
    }

    println("fail count:");
    println(to_str(fail));

    return fail;
}
