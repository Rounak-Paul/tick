var dtor_called : i32 = 0;

class Resource {
    var id : i32;

    func Resource(val : i32) : void {
        this.id = val;
    }

    func ~Resource() : void {
        dtor_called = dtor_called + 1;
    }

    func get_id() : i32 {
        return this.id;
    }
}

func make_resource() : void {
    var r : Resource = Resource(42);
    if (r.get_id() != 42) {
        println("FAIL: resource id wrong");
    }
}

func main() : i32 {
    dtor_called = 0;
    make_resource();

    if (dtor_called != 1) {
        println(dtor_called);
        return 1;
    }

    println("PASS: raii");
    return 0;
}
