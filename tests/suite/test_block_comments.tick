/* Test that block comments work properly */

func /* inline comment */ add(a : i32, b : i32) : i32 {
    return a + b;
}

/* Multi-line
   block comment
   test */
func main() : i32 {
    var pass : i32 = 0;
    var fail : i32 = 0;

    println("=== Block Comments Test ===");

    var x : i32 = add(10, 20); /* end of line comment */
    if (x == 30) {
        println("PASS: block comment inline");
        pass = pass + 1;
    } else {
        println("FAIL: block comment inline");
        fail = fail + 1;
    }

    /* nested arithmetic after comments */
    var y : i32 = 5 * 3 + 2;
    if (y == 17) {
        println("PASS: code after block comment");
        pass = pass + 1;
    } else {
        println("FAIL: code after block comment");
        fail = fail + 1;
    }

    println("Passed: ");
    println(pass);
    println("Failed: ");
    println(fail);

    return fail;
}
