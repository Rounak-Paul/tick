signal int_array : i32[];
signal done : i32;

event worker_event;

var int_sum : i32 = 0;

@worker_event process array_receiver {
    var ints : i32[] = int_array.recv();
    int_sum = ints[0] + ints[1] + ints[2];
    done.emit(1);
}

func main() : i32 {
    var pass : i32 = 0;
    var fail : i32 = 0;
    
    println("=== Signal Array Types Test ===");
    
    var nums : i32[] = [10, 20, 30];
    int_array.emit(nums);
    
    worker_event.execute();
    var sync : i32 = done.recv();
    
    if (int_sum == 60) {
        println("PASS: i32 array signal");
        pass = pass + 1;
    } else {
        println("FAIL: i32 array signal");
        fail = fail + 1;
    }
    
    println("Passed: ");
    println(pass);
    println("Failed: ");
    println(fail);
    
    return fail;
}
