func consume_array(arr : i32[]) : i32 {
    return arr.length();
}

func grow_array(arr : i32[], n : i32) : void {
    var i : i32 = 0;
    while (i < n) {
        arr.push(i);
        i = i + 1;
    }
}

func early_return_array(flag : b8) : i32 {
    var arr : i32[] = [1, 2, 3, 4, 5];
    if (flag) {
        return arr.length();
    }
    arr.push(100);
    return arr.length();
}

func nested_scope_arrays() : i32 {
    var result : i32 = 0;
    if (true) {
        var a : i32[] = [10, 20, 30];
        result = result + a.length();
        if (true) {
            var b : i32[] = [40, 50];
            result = result + b.length();
        }
    }
    return result;
}

func loop_array_creation() : i32 {
    var total : i32 = 0;
    var i : i32 = 0;
    while (i < 100) {
        var tmp : i32[] = [i, i + 1, i + 2];
        total = total + tmp.length();
        i = i + 1;
    }
    return total;
}

func break_with_array() : i32 {
    var result : i32 = 0;
    var i : i32 = 0;
    while (i < 50) {
        var arr : i32[] = [i, i * 2, i * 3];
        result = result + arr[0];
        if (i == 25) {
            break;
        }
        i = i + 1;
    }
    return result;
}

func continue_with_array() : i32 {
    var total : i32 = 0;
    var i : i32 = 0;
    while (i < 100) {
        var arr : i32[] = [i];
        i = i + 1;
        if (i % 2 == 0) {
            continue;
        }
        total = total + arr[0];
    }
    return total;
}

func for_break_array() : i32 {
    var result : i32 = 0;
    for (var i : i32 = 0; i < 50; i = i + 1) {
        var arr : i32[] = [i, i + 1];
        result = result + arr[0];
        if (i == 10) {
            break;
        }
    }
    return result;
}

func for_continue_array() : i32 {
    var total : i32 = 0;
    for (var i : i32 = 0; i < 100; i = i + 1) {
        var arr : i32[] = [i, i * 2];
        if (i % 3 == 0) {
            continue;
        }
        total = total + arr[0];
    }
    return total;
}

func empty_array_scope() : i32 {
    var arr : i32[];
    return arr.length();
}

func manual_free_then_scope() : i32 {
    var arr : i32[] = [1, 2, 3];
    var len : i32 = arr.length();
    free(arr);
    return len;
}

func pass_and_grow() : i32 {
    var arr : i32[];
    grow_array(arr, 500);
    var result : i32 = arr.length();
    return result;
}

func nested_loop_arrays() : i32 {
    var total : i32 = 0;
    var i : i32 = 0;
    while (i < 20) {
        var outer : i32[] = [i];
        var j : i32 = 0;
        while (j < 20) {
            var inner : i32[] = [j];
            total = total + inner[0];
            j = j + 1;
        }
        total = total + outer[0];
        i = i + 1;
    }
    return total;
}

func large_alloc_free() : i32 {
    var arr : i32[];
    var i : i32 = 0;
    while (i < 10000) {
        arr.push(i);
        i = i + 1;
    }
    var len : i32 = arr.length();
    return len;
}

func repeated_alloc_in_loop() : i32 {
    var count : i32 = 0;
    var i : i32 = 0;
    while (i < 500) {
        var a : i32[] = [1, 2, 3, 4, 5, 6, 7, 8];
        count = count + a.length();
        i = i + 1;
    }
    return count;
}

func main() : i32 {
    var r1 : i32 = early_return_array(true);
    if (r1 == 5) {
        println("PASS: early return with array (true)");
    } else {
        println("FAIL: early return with array (true)");
    }

    var r2 : i32 = early_return_array(false);
    if (r2 == 6) {
        println("PASS: early return with array (false)");
    } else {
        println("FAIL: early return with array (false)");
    }

    var r3 : i32 = nested_scope_arrays();
    if (r3 == 5) {
        println("PASS: nested scope arrays");
    } else {
        println("FAIL: nested scope arrays");
    }

    var r4 : i32 = loop_array_creation();
    if (r4 == 300) {
        println("PASS: loop array creation");
    } else {
        println("FAIL: loop array creation");
    }

    var r5 : i32 = break_with_array();
    if (r5 == 325) {
        println("PASS: break with array");
    } else {
        println("FAIL: break with array");
    }

    var r6 : i32 = continue_with_array();
    if (r6 == 2450) {
        println("PASS: continue with array");
    } else {
        println("FAIL: continue with array");
    }

    var r7 : i32 = for_break_array();
    if (r7 == 55) {
        println("PASS: for break with array");
    } else {
        println("FAIL: for break with array");
    }

    var r8 : i32 = for_continue_array();
    if (r8 == 3267) {
        println("PASS: for continue with array");
    } else {
        println("FAIL: for continue with array");
    }

    var r9 : i32 = empty_array_scope();
    if (r9 == 0) {
        println("PASS: empty array scope exit");
    } else {
        println("FAIL: empty array scope exit");
    }

    var r10 : i32 = manual_free_then_scope();
    if (r10 == 3) {
        println("PASS: manual free then scope exit");
    } else {
        println("FAIL: manual free then scope exit");
    }

    var r11 : i32 = pass_and_grow();
    if (r11 == 500) {
        println("PASS: pass empty and grow via callee");
    } else {
        println("FAIL: pass empty and grow via callee");
    }

    var r12 : i32 = nested_loop_arrays();
    if (r12 == 3990) {
        println("PASS: nested loop arrays");
    } else {
        println("FAIL: nested loop arrays");
    }

    var r13 : i32 = large_alloc_free();
    if (r13 == 10000) {
        println("PASS: large alloc scope exit");
    } else {
        println("FAIL: large alloc scope exit");
    }

    var r14 : i32 = repeated_alloc_in_loop();
    if (r14 == 4000) {
        println("PASS: repeated alloc in loop");
    } else {
        println("FAIL: repeated alloc in loop");
    }

    return 0;
}
